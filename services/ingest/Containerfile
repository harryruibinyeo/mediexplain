# Red Hat UBI9 Python 3.11 base image
# UBI (Universal Base Image) is Red Hat's officially supported enterprise base
# — required for OpenShift compatibility and the Red Hat portfolio demo
FROM registry.access.redhat.com/ubi9/python-311:latest

# /opt/app-root/src is UBI9's default app directory — already owned by
# the non-root user (uid 1001) so pip can write during build
WORKDIR /opt/app-root/src

COPY pyproject.toml .
# Install CPU-only PyTorch before everything else.
# sentence-transformers depends on torch — without this pip pulls the full
# CUDA build (~2GB). The ingest service only generates embeddings and runs
# perfectly on CPU. This cuts the image build download to ~200MB.
RUN pip install --no-cache-dir torch --index-url https://download.pytorch.org/whl/cpu
RUN pip install --no-cache-dir .

COPY main.py .

VOLUME ["/data/raw"]

ENTRYPOINT ["python", "main.py"]
