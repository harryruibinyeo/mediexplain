# Red Hat UBI9 Python 3.11 base image
# UBI (Universal Base Image) is Red Hat's officially supported enterprise base
# — required for OpenShift compatibility and the Red Hat portfolio demo
FROM registry.access.redhat.com/ubi9/python-311:latest

WORKDIR /app

# Copy dependency manifest first so Podman can cache this layer.
# If only main.py changes on rebuild, this pip install step is skipped.
COPY pyproject.toml .
RUN pip install --no-cache-dir .

# Copy the ingest script
COPY main.py .

# Mount point for the scraped JSON files (supplied at runtime via -v)
VOLUME ["/data/raw"]

ENTRYPOINT ["python", "main.py"]
