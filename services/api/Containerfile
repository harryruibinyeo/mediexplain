# Red Hat UBI9 Python 3.11 base image
FROM registry.access.redhat.com/ubi9/python-311:latest

WORKDIR /opt/app-root/src

COPY pyproject.toml .
# Install CPU-only PyTorch before everything else.
# sentence-transformers depends on torch — without this pip pulls the full
# CUDA build (~2GB). The API service only embeds short query strings
# which runs fast enough on CPU. GPU is only needed in the inference service.
RUN pip install --no-cache-dir torch --index-url https://download.pytorch.org/whl/cpu
RUN pip install --no-cache-dir .

COPY main.py agent.py tools.py .

# FastAPI serves on port 8001
EXPOSE 8001

ENTRYPOINT ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8001"]
