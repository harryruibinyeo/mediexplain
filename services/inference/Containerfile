# Red Hat UBI9 Python 3.11 base image
# vLLM requires Python 3.11 and CUDA 12.1+
FROM registry.access.redhat.com/ubi9/python-311:latest

WORKDIR /opt/app-root/src

# Upgrade pip — vLLM requires a recent version
RUN pip install --no-cache-dir --upgrade pip

# Install vLLM with CUDA support
# vLLM bundles its own CUDA runtime — no system CUDA toolkit required
RUN pip install --no-cache-dir vllm

COPY entrypoint.sh .

# vLLM serves on port 8000 (OpenAI-compatible API)
EXPOSE 8000

ENTRYPOINT ["bash", "entrypoint.sh"]
